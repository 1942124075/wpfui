    <!--  Elevation border brushes  -->

    <LinearGradientBrush EndPoint="0,3" MappingMode="Absolute" StartPoint="0,0" x:Key="ControlElevationBorderBrush" x:Shared="false">
        <!--<LinearGradientBrush.RelativeTransform>
            <ScaleTransform CenterY="0.5" ScaleY="-1" />
        </LinearGradientBrush.RelativeTransform>-->
        <LinearGradientBrush.GradientStops>
            <GradientStop Color="{StaticResource ControlStrokeColorSecondary}" Offset="0.33" />
            <GradientStop Color="{StaticResource ControlStrokeColorDefault}" Offset="1.0" />
        </LinearGradientBrush.GradientStops>
    </LinearGradientBrush>

    <LinearGradientBrush EndPoint="0,1" MappingMode="RelativeToBoundingBox" StartPoint="0,0" x:Key="CircleElevationBorderBrush">
        <LinearGradientBrush.GradientStops>
            <GradientStop Color="{StaticResource ControlStrokeColorSecondary}" Offset="0.70" />
            <GradientStop Color="{StaticResource ControlStrokeColorDefault}" Offset="0.50" />
        </LinearGradientBrush.GradientStops>
    </LinearGradientBrush>

    <LinearGradientBrush EndPoint="0,3" MappingMode="Absolute" StartPoint="0,0" x:Key="AccentControlElevationBorderBrush" x:Shared="false">
        <LinearGradientBrush.RelativeTransform>
            <ScaleTransform CenterY="0.5" ScaleY="-1" />
        </LinearGradientBrush.RelativeTransform>
        <LinearGradientBrush.GradientStops>
            <GradientStop Color="{StaticResource ControlStrokeColorOnAccentSecondary}" Offset="0.33" />
            <GradientStop Color="{StaticResource ControlStrokeColorOnAccentDefault}" Offset="1.0" />
        </LinearGradientBrush.GradientStops>
    </LinearGradientBrush>

    <LinearGradientBrush EndPoint="0,3" MappingMode="Absolute" StartPoint="0,0" x:Key="TextControlElevationBorderBrush" x:Shared="false">
        <!--<LinearGradientBrush.RelativeTransform>
            <ScaleTransform CenterY="0.5" ScaleY="-1" />
        </LinearGradientBrush.RelativeTransform>-->
        <LinearGradientBrush.GradientStops>
            <GradientStop Color="{StaticResource ControlStrokeColorSecondary}" Offset="0.33" />
            <GradientStop Color="{StaticResource ControlStrokeColorDefault}" Offset="1.0" />
        </LinearGradientBrush.GradientStops>
    </LinearGradientBrush>

    <DrawingBrush
        Stretch="UniformToFill"
        TileMode="Tile"
        Viewport="0,0,10,10"
        ViewportUnits="Absolute"
        x:Key="StripedBackgroundBrush">
        <DrawingBrush.Drawing>
            <DrawingGroup>
                <DrawingGroup.Children>
                    <GeometryDrawing Brush="#0DFFFFFF">
                        <GeometryDrawing.Geometry>
                            <GeometryGroup FillRule="Nonzero">
                                <PathGeometry>
                                    <PathFigure StartPoint="0,0">
                                        <LineSegment Point="25,0" />
                                        <LineSegment Point="100,75" />
                                        <LineSegment Point="100,100" />
                                        <LineSegment Point="75,100" />
                                        <LineSegment Point="0,25" />
                                        <LineSegment Point="0,0" />
                                    </PathFigure>
                                    <PathFigure StartPoint="75,0">
                                        <LineSegment Point="100,25" />
                                        <LineSegment Point="100,0" />
                                    </PathFigure>
                                    <PathFigure StartPoint="0,75">
                                        <LineSegment Point="25,100" />
                                        <LineSegment Point="0,100" />
                                    </PathFigure>
                                </PathGeometry>
                            </GeometryGroup>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingGroup.Children>
            </DrawingGroup>
        </DrawingBrush.Drawing>
    </DrawingBrush>


